      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "id": 13,
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "sum(deepfake_inference_processing_seconds_sum) / sum(deepfake_inference_processing_seconds_count)", "legendFormat": "Avg inference (s)", "refId": "A"},
        {"datasource": {"type": "prometheus"}, "expr": "sum(deepfake_request_processing_seconds_sum) / sum(deepfake_request_processing_seconds_count)", "legendFormat": "Avg request (s)", "refId": "B"},
        {"datasource": {"type": "prometheus"}, "expr": "sum(deepfake_preprocessing_processing_seconds_sum) / sum(deepfake_preprocessing_processing_seconds_count)", "legendFormat": "Avg preprocessing (s)", "refId": "C"}
      ],
      "title": "Summary — Average Processing Times (s)",
      "type": "timeseries"
    },

