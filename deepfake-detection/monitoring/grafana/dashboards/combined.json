    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "title": "Inference & Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 10,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "sum by (mode) (rate(deepfake_requests_total{status=\"200\"}[5m]))", "legendFormat": "success {{mode}}", "refId": "A"},
