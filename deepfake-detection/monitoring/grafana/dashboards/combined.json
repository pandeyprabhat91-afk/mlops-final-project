      "gridPos": {"h": 4, "w": 5, "x": 4, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(rate(deepfake_requests_total[5m]))", "legendFormat": "req/s", "refId": "A"}],
      "title": "Request Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}, "unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 5, "x": 9, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "sum(rate(deepfake_errors_total[5m])) / sum(rate(deepfake_requests_total[5m]))", "legendFormat": "Error %", "refId": "A"}],
      "title": "Error Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 2.0}, {"color": "red", "value": 3.0}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 14, "y": 1},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "deepfake_drift_score", "legendFormat": "Drift", "refId": "A"}],
      "title": "Drift Score",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "mbytes"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 5,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "value"},
      "targets": [{"datasource": {"type": "prometheus"}, "expr": "deepfake_model_memory_mb", "legendFormat": "Model RAM", "refId": "A"}],
      "title": "Model Memory",
      "type": "stat"
