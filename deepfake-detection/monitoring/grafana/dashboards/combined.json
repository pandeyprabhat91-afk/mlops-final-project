        {"datasource": {"type": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le, prediction) (rate(deepfake_confidence_score_bucket[10m])))", "legendFormat": "p95 conf {{prediction}}", "refId": "B"}
