      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 11,
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "histogram_quantile(0.99, sum by (le,mode) (rate(deepfake_inference_latency_ms_bucket[5m])))", "legendFormat": "p99 {{mode}}", "refId": "A"},
        {"datasource": {"type": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le,mode) (rate(deepfake_inference_latency_ms_bucket[5m])))", "legendFormat": "p95 {{mode}}", "refId": "B"},
        {"datasource": {"type": "prometheus"}, "expr": "histogram_quantile(0.50, sum by (le,mode) (rate(deepfake_inference_latency_ms_bucket[5m])))", "legendFormat": "p50 {{mode}}", "refId": "C"}
      ],
      "title": "Inference Latency p50/p95/p99 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "id": 12,
      "targets": [
        {"datasource": {"type": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le,mode) (rate(deepfake_preprocessing_latency_ms_bucket[5m])))", "legendFormat": "preprocessing p95 {{mode}}", "refId": "A"},
        {"datasource": {"type": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le,mode) (rate(deepfake_request_latency_seconds_bucket[5m]))) * 1000", "legendFormat": "request p95 {{mode}}", "refId": "B"}
      ],
      "title": "Preprocessing vs Request Latency p95 (ms)",
