{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Airflow data pipeline monitoring — task durations and throughput",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "airflow_task_duration",
          "legendFormat": "{{task_id}}",
          "refId": "A"
        }
      ],
      "title": "Airflow Task Durations",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(airflow_dag_run_duration_sum[5m]) / rate(airflow_dag_run_duration_count[5m])",
          "legendFormat": "Avg DAG run duration",
          "refId": "A"
        }
      ],
      "title": "DAG Run Duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "increase(pipeline_validation_failures_total[1h])",
          "legendFormat": "Validation failures",
          "refId": "A"
        }
      ],
      "title": "Pipeline Validation Failures (last 1h)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(airflow_dag_run_success_total[1h])",
          "legendFormat": "DAG success rate",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "rate(airflow_dag_run_failed_total[1h])",
          "legendFormat": "DAG failure rate",
          "refId": "B"
        }
      ],
      "title": "DAG Success vs Failure Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["deepfake", "pipeline", "airflow"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Data Pipeline",
  "uid": "deepfake-pipeline",
  "version": 1
}
